{
  "version": "vnext-1",
  "purpose": "Machine-readable contract for physical-space visibility and partial user control boundaries.",
  "visibility_contract": {
    "user_must_be_able_to": [
      "see_current_card_physical_position",
      "browse_library_group_box_card_hierarchy",
      "inspect_box_contents"
    ]
  },
  "position_control_model": {
    "algorithm_is_primary_driver": true,
    "user_has_partial_control": true,
    "allowed_user_operations": [
      "browse_and_enter_space_regions",
      "inspect_card_positions_and_box_contents",
      "apply_or_remove_favorite_tag",
      "move_card_into_or_out_of_sleep_zone",
      "use_only_explicitly_supported_position_adjustment_actions"
    ],
    "disallowed_user_operations": [
      "arbitrarily_reassign_card_to_any_box",
      "rewrite_box_knowledge_ownership",
      "turn_favorite_into_physical_container",
      "fully_override_algorithmic_positioning_without_supported_action"
    ]
  },
  "space_state_rules": {
    "favorite_rule": "favorite_is_tag_not_physical_box",
    "sleep_rule": "cards_in_sleep_zone_do_not_appear_in_learning_flow_until_removed",
    "sleep_rule_visibility": "product_should_make_the_sleep_flow_effect_understandable_to_users"
  },
  "dependency_contract": {
    "knowledge_ownership_source": "spec/box-catalog.json",
    "product_semantics_source": "spec/product-core.json"
  }
}
