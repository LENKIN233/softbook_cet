{
  "version": "vnext-5",
  "layer": "repo_governance_truth",
  "purpose": "Define the architecture of scripts/validate_harness.py and the independent local quality-gate entrypoint so governance checks stay layered while runtime and release jobs remain delegated and diagnosable.",
  "authority_note": "This file owns validator layer boundaries, section ownership, and side-effect policy. It does not own product truth, UI design truth, workspace classification, or PR delivery policy; those remain in their owner specs.",
  "product_truth": {
    "none": "Harness architecture is repo governance truth, not product truth. It protects product truth by making validator responsibilities explicit."
  },
  "runner_contract": {
    "entrypoint": "scripts/validate_harness.py",
    "implementation": "scripts/harness_validator/runner.py",
    "default_mode": "full",
    "default_no_argument_semantics": "run_all_sections_and_require_remote_github_protection_read",
    "modes": {
      "local": {
        "remote_guard": "forbidden",
        "completeness": "partial"
      },
      "full": {
        "remote_guard": "required_when_delivery_runtime_is_selected",
        "completeness": "complete_only_when_all_sections_run"
      }
    },
    "compatibility_aliases": {
      "--skip-remote-guard": "--mode local"
    },
    "selectors": [
      "--layer",
      "--section"
    ],
    "selection_dependency_policy": "declared_logical_prerequisites_are_added_and_reported_in_selected_sections",
    "section_dependencies": {
      "agent_review_regressions": [
        "governance_contracts"
      ],
      "delivery_runtime": [
        "governance_contracts"
      ]
    },
    "section_interface": "def validate(context) -> None",
    "execution_model": {
      "isolation": "one_python_worker_process_per_selected_section",
      "default_timeout_seconds": 30,
      "timeout_behavior": "terminate_worker_process_group_record_timeout_finding_and_continue",
      "worker_protocol": "json_errors_exception_and_remote_guard_execution"
    },
    "context_profiles": {
      "read_only": {
        "sections": [
          "prelude",
          "truth_mirrors",
          "harness_architecture",
          "product_contract_mirrors",
          "visual_language",
          "workspace_boundary",
          "governance_contracts",
          "agent_run_record",
          "design_contracts"
        ],
        "capabilities": [
          "read_repository_files",
          "load_specs",
          "record_findings"
        ]
      },
      "delivery": {
        "sections": [
          "delivery_runtime"
        ],
        "capabilities": [
          "allowlisted_git_reads",
          "github_api_get",
          "allowlisted_local_validator",
          "isolated_temporary_directory"
        ]
      },
      "fixture": {
        "sections": [
          "mobile_metadata_regressions",
          "design_metadata_regressions",
          "design_search_regressions",
          "agent_review_regressions",
          "pr_design_gate_regressions"
        ],
        "capabilities": [
          "isolated_system_temporary_directory",
          "section_exact_local_validator_allowlist",
          "controlled_fixture_copy_and_removal",
          "pr_body_only_environment_override",
          "no_remote_or_repository_mutation"
        ]
      }
    },
    "capability_enforcement": {
      "implementations": [
        "scripts/harness_validator/context.py",
        "scripts/harness_validator/capability_ast.py"
      ],
      "runtime_context_profiles_enforced": true,
      "read_only_profile_forbidden_imports_and_calls": true,
      "all_sections_explicit_validate_context": true,
      "direct_process_network_and_temp_imports_forbidden": true,
      "repository_derived_fixture_writes_forbidden": true,
      "exec_calls_forbidden": true,
      "github_api_get_full_mode_only": true,
      "runtime_smoke_sections_forbidden": true,
      "executable_top_level_statements_forbidden": true,
      "validate_context_signature_required": true
    },
    "formats": [
      "text",
      "json"
    ],
    "supporting_options": [
      "--output",
      "--list",
      "--profile"
    ],
    "exit_codes": {
      "passed": 0,
      "failed": 1,
      "invalid_arguments": 2
    },
    "result_contract": {
      "schema_version": "harness-result.v1",
      "required_top_level_fields": [
        "schema_version",
        "status",
        "exit_code",
        "mode",
        "started_at",
        "duration_ms",
        "completeness",
        "selection",
        "summary",
        "sections",
        "findings"
      ],
      "required_finding_fields": [
        "layer",
        "section",
        "type",
        "message"
      ],
      "section_status_values": [
        "passed",
        "failed",
        "skipped"
      ],
      "completeness_values": [
        "complete",
        "partial"
      ],
      "partial_pass_is_not_full_validation": true,
      "section_exception_isolated": true,
      "section_timeout_isolated": true,
      "capability_violation_is_finding": true
    },
    "unit_test_command": "python3 scripts/test_validate_harness_runner.py",
    "boundary_test_command": "python3 scripts/test_harness_module_boundaries.py"
  },
  "local_gate_runner_contract": {
    "entrypoint": "scripts/run_local_gates",
    "implementation": "scripts/local_gates/runner.py",
    "supporting_modules": [
      "scripts/local_gates/model.py",
      "scripts/local_gates/execution.py",
      "scripts/local_gates/checks.py",
      "scripts/local_gates/catalog.py"
    ],
    "independent_from_validate_harness": true,
    "profiles": {
      "dev": {
        "network": "forbidden_by_catalog_and_os_enforced_outbound_denial",
        "includes": [
          "local_harness_and_harness_regressions",
          "local_gate_runner_regressions",
          "launch_readiness_contract",
          "maestro_selector_contract",
          "mobile_metadata_lint_typecheck_and_jest",
          "backend_contract_tests"
        ]
      },
      "pr": {
        "extends": "dev",
        "requires_unique_current_pull_request": true,
        "includes": [
          "full_remote_harness",
          "real_pull_request_body_gates",
          "dependency_security_with_visible_exceptions",
          "strict_local_and_remote_repository_health",
          "git_lfs_fsck",
          "remote_agent_evidence_validation"
        ]
      },
      "release": {
        "extends": "pr",
        "platform": "macos_only",
        "includes": [
          "ruby_and_bundler_preflight",
          "cocoapods_deployment_lock",
          "release_simulator_build",
          "unsigned_release_archive"
        ]
      }
    },
    "cli": [
      "--profile dev|pr|release",
      "--base <ref>",
      "--pr <number>",
      "--output <path>",
      "--verbose",
      "--fail-fast"
    ],
    "execution": {
      "collect_all_by_default": true,
      "dependency_staged_parallelism": true,
      "fail_fast_is_diagnostic_only": true,
      "fail_fast_cannot_produce_complete_pass": true,
      "explicit_timeout_per_gate": true,
      "timeout_terminates_process_group": true,
      "gate_exception_isolated": true,
      "network_false_gate_requires_os_isolation": true,
      "tracked_worktree_must_be_unchanged": true
    },
    "toolchains": {
      "python": "3.12.x",
      "node": "22.13.0",
      "ruby": "3.3.x",
      "dev_compatible_node_drift": "passed_with_exception",
      "pr_and_release_drift": "failed"
    },
    "output_policy": {
      "root": "exports/local-gates/",
      "root_is_ignored": true,
      "logs_are_redacted": true,
      "arguments_are_redacted": true,
      "environment_values_are_redacted": true,
      "raw_pull_request_body_is_not_persisted": true
    },
    "result_contract": {
      "schema_version": "local-gate-report.v1",
      "required_top_level_fields": [
        "schema_version",
        "profile",
        "status",
        "exit_code",
        "complete",
        "head",
        "base",
        "pull_request",
        "toolchain",
        "network_isolation",
        "workspace",
        "safe_exceptions",
        "remote_checks",
        "summary",
        "gates",
        "formal_state_updates"
      ],
      "status_values": [
        "passed",
        "passed_with_exception",
        "failed",
        "skipped",
        "deferred"
      ],
      "deferred_cannot_satisfy_pr_or_release": true,
      "dependency_exception_must_expose_severity_and_vulnerability_counts": true
    },
    "formal_state_boundaries": {
      "may_update_pull_request_review": false,
      "may_update_content_approval": false,
      "may_update_launch_readiness": false,
      "may_replace_github_required_checks": false
    },
    "unit_test_command": "python3 scripts/test_run_local_gates.py",
    "dev_performance_target": "five_warm_run_median_not_above_15_seconds"
  },
  "layers": [
    {
      "id": "bootstrap_layer",
      "name": "Bootstrap spec readability",
      "sections": [
        "prelude"
      ],
      "responsibility": "Verify that required active specs are independently readable without creating shared section state.",
      "side_effect_policy": "local_read_and_environment_setup_only",
      "allowed_operations": [
        "read_local_specs",
        "define_helpers",
        "set_python_no_bytecode"
      ],
      "forbidden_operations": [
        "git",
        "gh",
        "network",
        "temporary_fixture_generation"
      ]
    },
    {
      "id": "truth_spec_layer",
      "name": "Truth and spec consistency",
      "sections": [
        "truth_mirrors",
        "harness_architecture",
        "product_contract_mirrors",
        "visual_language"
      ],
      "responsibility": "Check active truth, owner/mirror consistency, product contract mirrors, and visual-language mirrors using local files only.",
      "side_effect_policy": "pure_local_file_checks",
      "allowed_operations": [
        "read_local_files",
        "compare_json_and_text_anchors"
      ],
      "forbidden_operations": [
        "git",
        "gh",
        "network",
        "subprocess",
        "temporary_fixture_generation"
      ]
    },
    {
      "id": "workspace_hygiene_layer",
      "name": "Workspace hygiene and context boundary",
      "sections": [
        "workspace_boundary"
      ],
      "responsibility": "Check active workspace classification and default agent read boundaries without inspecting generated dependency trees.",
      "side_effect_policy": "pure_local_file_checks",
      "allowed_operations": [
        "read_local_specs",
        "read_gitignore_files"
      ],
      "forbidden_operations": [
        "git",
        "gh",
        "network",
        "bulk_generated_or_dependency_reads",
        "temporary_fixture_generation"
      ]
    },
    {
      "id": "delivery_governance_layer",
      "name": "Delivery governance and PR gates",
      "sections": [
        "governance_contracts",
        "agent_run_record",
        "agent_review_regressions",
        "delivery_runtime"
      ],
      "responsibility": "Check branch policy, hooks, branch protection, workflow wiring, Agent review regressions, PR body gates, and local delivery validators.",
      "side_effect_policy": "allowed_local_commands_and_remote_github_reads",
      "allowed_operations": [
        "git_read_commands",
        "gh_branch_protection_read",
        "local_subprocess_validators",
        "temporary_selector_fixtures"
      ],
      "forbidden_operations": [
        "repository_mutation",
        "dependency_install",
        "build_outputs",
        "runtime_deployment"
      ]
    },
    {
      "id": "design_governance_layer",
      "name": "Design governance and design-search regressions",
      "sections": [
        "design_contracts",
        "mobile_metadata_regressions",
        "design_metadata_regressions",
        "design_search_regressions",
        "pr_design_gate_regressions"
      ],
      "responsibility": "Check design artifact lifecycle, quarantine, single-card UX contract, design-search fixtures, and visual-output PR gate regressions.",
      "side_effect_policy": "allowed_temporary_design_fixtures_no_remote",
      "allowed_operations": [
        "read_design_artifacts",
        "temporary_fixture_generation",
        "local_design_validator_subprocess"
      ],
      "forbidden_operations": [
        "git",
        "gh",
        "network",
        "repository_mutation",
        "runtime_deployment"
      ]
    },
    {
      "id": "runtime_smoke_layer",
      "name": "Runtime smoke and app/backend behavior",
      "sections": [],
      "ci_jobs": [
        "backend-contract",
        "mobile-quality"
      ],
      "responsibility": "Runtime behavior is verified by dedicated CI jobs, not by the pure harness layers. validate_harness.py may check that those jobs are wired, but it must not become the runtime smoke runner.",
      "side_effect_policy": "delegated_to_ci_jobs",
      "allowed_operations": [
        "workflow_wiring_checks"
      ],
      "forbidden_operations": [
        "run_mobile_tests_inside_validate_harness",
        "run_backend_tests_inside_validate_harness",
        "deploy_cloudbase_inside_validate_harness"
      ]
    }
  ],
  "runner_section_order": [
    "prelude",
    "truth_mirrors",
    "harness_architecture",
    "product_contract_mirrors",
    "visual_language",
    "workspace_boundary",
    "governance_contracts",
    "agent_run_record",
    "agent_review_regressions",
    "delivery_runtime",
    "design_contracts",
    "mobile_metadata_regressions",
    "design_metadata_regressions",
    "design_search_regressions",
    "pr_design_gate_regressions"
  ],
  "pure_sections": [
    "prelude",
    "truth_mirrors",
    "harness_architecture",
    "product_contract_mirrors",
    "visual_language",
    "workspace_boundary",
    "design_contracts"
  ],
  "sections_allowed_subprocess_or_tempfiles": [
    "delivery_runtime",
    "agent_review_regressions",
    "mobile_metadata_regressions",
    "design_metadata_regressions",
    "design_search_regressions",
    "pr_design_gate_regressions"
  ],
  "sections_allowed_remote_github_reads": [
    "delivery_runtime"
  ],
  "anti_patterns": [
    {
      "id": "HA-AP-01",
      "name": "add_new_harness_check_without_layer_owner",
      "correction": "assign_every_section_to_one_harness_architecture_layer_before_adding_checks"
    },
    {
      "id": "HA-AP-02",
      "name": "put_remote_or_runtime_side_effects_in_truth_or_workspace_layers",
      "correction": "keep_truth_spec_and_workspace_hygiene_layers_pure_and_move side effects into delivery governance or CI runtime smoke jobs"
    },
    {
      "id": "HA-AP-03",
      "name": "use_validate_harness_as_runtime_test_runner",
      "correction": "validate_harness_checks_governance_and_contract_wiring_runtime_behavior_belongs_to_backend_contract_and_mobile_quality_jobs"
    },
    {
      "id": "HA-AP-04",
      "name": "treat_partial_or_local_harness_result_as_complete",
      "correction": "require_full_mode_all_sections_and_remote_guard_before_claiming_complete_harness_validation"
    },
    {
      "id": "HA-AP-05",
      "name": "share_mutable_section_globals_or_use_exec_in_harness_runtime",
      "correction": "run_each_section_as_validate_context_in_an_isolated_worker_and_forbid_exec_throughout_the_harness_runtime"
    },
    {
      "id": "HA-AP-06",
      "name": "let_fixture_regressions_write_repository_derived_paths_or_run_arbitrary_validators",
      "correction": "use_the_section_exact_fixture_context_allowlist_and_system_temporary_roots_with_ast_repository_path_guards"
    }
  ]
}
