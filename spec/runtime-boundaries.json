{
  "version": "vnext-7",
  "product_level_requirements": [
    "frontend_core_is_react_native",
    "support_ios_android_web_release_targets",
    "support_phone_tablet_pc_web_device_classes",
    "do_not_use_one_ui_to_adapt_everywhere",
    "keep_top_level_navigation_consistent_as_learning_space_statistics_mine",
    "main_flow_stays_single_card",
    "main_learning_flow_and_physical_space_remain_top_level_product_capabilities_on_all_release_targets",
    "physical_space_is_real_product_capability",
    "login_is_required_before_learning_starts",
    "phone_sms_code_is_the_primary_login_method",
    "trial_and_membership_access_rules_are_enforced",
    "confirmed_user_facing_actions_are_not_dropped",
    "daily_level_progress_sync_exists",
    "membership_entitlement_is_shared_across_ios_android_web",
    "all_release_targets_support_purchase",
    "audio_resources_are_available_on_all_release_targets"
  ],
  "minimum_responsibility_split": {
    "client": [
      "render_cards_and_interactions",
      "play_audio_resources",
      "present_analysis_hint_layer_and_space",
      "explain_why_user_sees_a_card_when_needed",
      "keep_learning_cost_low",
      "provide_device_class_specific_ui_and_page_structure",
      "enforce_authenticated_entry_before_learning",
      "present_navigation_consistently_across_surfaces",
      "support_keyboard_shortcuts_and_mouse_on_non_touch_surfaces",
      "do_not_auto_play_audio"
    ],
    "service_or_scheduler": [
      "decide_card_order",
      "remember_card_position_and_access_state",
      "apply_trial_and_membership_matrix",
      "support_daily_level_progress_sync",
      "share_membership_entitlement_across_surfaces",
      "support_cross_device_resume_and_minimum_consistency",
      "validate_authenticated_user_context_for_learning_progress",
      "start_trial_when_first_entry_is_counted",
      "remind_for_purchase_recovery_after_membership_experience_ends"
    ]
  },
  "not_product_truth_yet": [
    "full_rest_endpoint_design",
    "complete_database_schema",
    "complex_state_machine_fields",
    "fine_grained_counters",
    "exact_scheduling_parameters"
  ],
  "implementation_hypotheses": [
    "a_scheduler_or_stateful_service_can_exist",
    "minimal_resume_capability_can_exist",
    "some_explanatory_state_can_be_exposed_to_client",
    "peek_runtime_semantics_can_be_defined_later_without_removing_peek_from_product_surface",
    "non_touch_surfaces_can_use_equivalent_interaction_mapping_without_forcing_literal_touch_gestures",
    "exact_same_card_cross_device_resume_is_not_required_if_daily_progress_sync_and_some_progress_inheritance_exist",
    "offline_use_can_be_allowed_for_authenticated_users_with_cached_state_and_content_only",
    "sync_conflict_resolution_can_use_server_authoritative_event_merging",
    "CloudBase physical-space canonical state uses database transactions so concurrent function instances retry read-merge-write conflicts",
    "production mobile builds require a complete remote runtime profile and never fall back to tracked development card sources",
    "the existing CloudBase NoSQL function remains a development and staging compatibility service while the production service uses PostgreSQL",
    "production authentication uses expiring access and rotating refresh sessions that can be revoked independently"
  ],
  "local_persistence": {
    "classification": "implementation_hypothesis",
    "auth_session_store": {
      "sensitive_value": "auth_token",
      "storage": "platform_keychain_or_keystore",
      "schema": "auth-session.v1",
      "must_not_use": "AsyncStorage",
      "non_sensitive_revocation_marker": "versioned_AsyncStorage tombstone is written before secure credential cleanup and blocks restoration until a new secure session is saved",
      "authorization_rejection": "HTTP 401 or 403 during restored-session authority reads clears account-bound persistence and returns to login"
    },
    "user_state_store": {
      "storage": "versioned_AsyncStorage",
      "schema": "user-state.v2",
      "owner_key": "phone_number",
      "scope": [
        "daily_check_in_key",
        "learning_cursor",
        "favorite_tags",
        "sleep_state"
      ],
      "corruption_behavior": "discard_invalid_payload_and_fall_back_to_empty_state",
      "migration": "user-state.v1 space entries receive an epoch timestamp so stale restored state cannot outrank server canonical state",
      "space_state_timestamp": "preserve the timestamp of each explicit favorite or sleep action"
    },
    "membership_state": "reload_from_server_authority_after_auth_session_restore",
    "mutation_queue": "persisted_under_an_independent_key_and_not_embedded_in_user_state",
    "logout": "persist auth revocation first, then clear auth session, user state, and account-bound mutation queue before presenting logged-out runtime state"
  },
  "decision_rule": {
    "if_runtime_conflicts_with_experience": [
      "prefer_product_experience",
      "adjust_algorithm_or_api",
      "only_then_discuss_experience_compromise"
    ]
  }
}
