{
  "version": "vnext-5",
  "purpose": "Default repository delivery contract for code-changing tasks: topic branch, commit and pull request path, agent review and merge behavior, PR body requirements, and CI gates.",
  "delivery_defaults": {
    "code_change_tasks": {
      "default_strategy": "topic_branch_commit_pull_request_agent_review_auto_merge",
      "topic_branch_required": true,
      "allowed_topic_branch_prefixes": [
        "infra/",
        "shell/",
        "module/",
        "cross/",
        "fix/"
      ],
      "local_only_requires_explicit_user_instruction": true,
      "pull_request_required_unless_local_only": true,
      "agent_review_required_before_merge": true,
      "auto_merge_after_agent_review_and_green_gates": true,
      "merge_blockers": [
        "blocking_review_findings",
        "required_gates_not_green",
        "pull_request_or_merge_permission_failure"
      ],
      "if_pull_request_cannot_be_created": "handoff_branch_commit_validation_and_blocker"
    }
  },
  "pull_request_contract": {
    "target_branch": "main",
    "default_action": "open_or_update_pull_request_then_review_and_merge_when_green",
    "required_body_sections": [
      "当前任务引用的 spec",
      "变更摘要",
      "验证",
      "设计稿来源（用户可见 UI 如适用）",
      "design_review_checklist（如适用）"
    ],
    "visual_output_rule": "if_visual_output_changes_exist_the_pull_request_must_answer_the_design_review_checklist",
    "user_facing_ui_design_gate": {
      "applies_when": "pull_request_changes_user_facing_UI_or_visual_state",
      "required_before_implementation": true,
      "accepted_sources": [
        "docs/design/visual-reference.html",
        "docs/design/canon.md",
        "docs/design/briefs/*.md",
        "docs/design/decisions/*.md",
        "docs/design/interaction-motion/*.md",
        "docs/design/physical-space/*.md",
        "docs/design/mocks/*.md",
        "docs/design/storyboards/*.md",
        "linked_external_design_file"
      ],
      "same_pull_request_design_artifact_rule": "design brief or decision added in the same PR may satisfy design-only work, but cannot satisfy an implementation PR that also changes user-facing UI",
      "task_local_design_brief_rule": "task-local design briefs may guide exploration but are not accepted implementation authority",
      "existing_code_is_not_design_authority": true,
      "implementation_without_design_artifact": "delivery_blocker",
      "pull_request_must_state": [
        "design_artifact_source",
        "interaction_motion_artifact_if_core_interaction_changes",
        "physical_space_artifact_if_space_changes",
        "implementation_mapping",
        "unimplemented_design_gaps_if_any",
        "design_review_checklist_answers"
      ],
      "core_product_capability_design_gate": {
        "learning_or_space_ui_requires_surface_specific_artifact": true,
        "core_interaction_ui_requires_interaction_motion_artifact": true,
        "space_ui_requires_physical_space_artifact": true,
        "core_surface_quality_requires_rendered_mock_or_storyboard_before_full_visual_completion": true
      }
    }
  },
  "ci_contract": {
    "workflow_path": ".github/workflows/pr-gates.yml",
    "pull_request_template_path": ".github/pull_request_template.md",
    "required_pull_request_gates": [
      {
        "id": "design_artifact_gate",
        "command": "python3 scripts/validate_pr_design_gate.py --base <base_sha> --head <head_sha>"
      },
      {
        "id": "validate_harness",
        "command": "python3 scripts/validate_harness.py --skip-remote-guard"
      },
      {
        "id": "mobile_lint",
        "command": "cd apps/mobile && npm run lint -- --quiet"
      },
      {
        "id": "mobile_typecheck",
        "command": "cd apps/mobile && npm run typecheck"
      },
      {
        "id": "mobile_test",
        "command": "cd apps/mobile && npm test -- --runInBand --watchAll=false"
      }
    ]
  }
}
