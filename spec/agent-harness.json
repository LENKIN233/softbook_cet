      "correction": "keep_learning_space_statistics_mine_consistent_while_adapting_page_composition"
    },
    {
      "id": "AP-17",
      "name": "make_trial_start_at_install_or_registration_instead_of_first_counted_entry",
      "correction": "trial_starts_when_first_entry_is_counted_as_membership_trial"
    },
    {
      "id": "AP-18",
      "name": "autoplay_audio_or_require_front_subtitles",
      "correction": "audio_does_not_autoplay_and_front_side_subtitles_are_not_required"
    },
    {
      "id": "AP-19",
      "name": "treat_module_selection_as_primary_learning_mode",
      "correction": "keep_system_sequenced_single_flow_primary_and_use_module_browsing_only_for_targeted_review"
    },
    {
      "id": "AP-20",
      "name": "treat_main_as_normal_development_branch",
      "correction": "main_is_read_only_integration_branch_and_topic_branches_are_required"
    },
    {
      "id": "AP-21",
      "name": "reinvent_visual_language_per_screen_or_per_agent",
      "correction": "inherit_from_spec_visual_language_json_and_docs_design_visual_reference_html_and_treat_hex_as_implementation_hypothesis_but_library_identity_and_self_assess_scoping_and_law_of_one_as_product_truth"
    },
    {
      "id": "AP-22",
      "name": "ship_visual_output_without_answering_design_review_checklist",
      "correction": "any_task_that_produces_visual_output_must_emit_answers_to_visual_language_design_review_checklist_universal_Q1_Q4_plus_applicable_conditional_Q5_Q6"
    },
    {
      "id": "AP-23",
      "name": "use_red_for_self_assess_review_level_implying_punishment",
      "correction": "self_assess_has_two_levels_confident_green_and_review_amber_red_is_reserved_for_rule_dont_and_trend_down_only"
    },
    {
      "id": "AP-24",
